# Loại server: mohist, forge, fabric, vanilla, spigot, paper, arclight, magma...
SERVER_TYPE=mohist

# Đường dẫn tải file jar (nếu để trống thì dùng file có sẵn trong thư mục server)
SERVER_JAR_URL=https://mohistmc.com/api/v2/versions/1.12.2/download

# Tên file jar
JAR_FILENAME=server.jar

# RAM
RAM=15G

# Tùy chọn Java
CUSTOM_JAVA_OPTS="-XX:+UseG1GC -XX:+ParallelRefProcEnabled"

# Thư mục trên Drive (sẽ tạo nếu chưa có)
DRIVE_FOLDER=MC_Server
